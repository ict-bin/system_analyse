# Environment variables for data_flow_analyse
# Copy to .env and fill in your values

# Required: At least one LLM API key
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Server config
PORT=3000
AGENTS_DIR=./agents
OUTPUT_DIR=./output

# Default model (optional, can be overridden per task)
# DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
