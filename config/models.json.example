{
    "providers": {
        "gaiasec": {
            "baseUrl": "http://gaiasec.ai.icsl.huawei.com/v1/",
            "api": "openai-completions",
            "apiKey": "GAIASEC_TOKEN",
            "compat": {
                "supportsDeveloperRole": false,
                "supportsReasoningEffort": false
            },
            "models": [
                {
                    "id": "auto",
                    "name": "auto",
                    "reasoning": false,
                    "input": ["text"],
                    "contextWindow": 128000,
                    "maxTokens": 8192,
                    "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
                }
            ]
        }
    }
}
